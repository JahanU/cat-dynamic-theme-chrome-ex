{
  "manifest_version": 3,
  "name": "Cat gifs Wallpaper",
  "version": "1.0",
  "description": "See a new cat gif everyday",
  "icons": {
    "16": "cat.png",
    "48": "cat.png",
    "128": "cat.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "tabs"
  ],
  "host_permissions": [
    "https://cataas.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.google.com/*"
      ],
      "css": [
        "style-google.css"
      ]
    },
    {
      "matches": [
        "https://search.brave.com/*"
      ],
      "css": [
        "style-brave.css"
      ],
      "js": [
        "content.js"
      ]
    }
  ]
}